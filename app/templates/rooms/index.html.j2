{% extends "base.html.j2" %}

{% block title %}Rooms - LiveKit Dashboard{% endblock %}

{% block page_title %}Rooms{% endblock %}

{% block page_subtitle %}
<p class="page-subtitle">Manage your LiveKit rooms</p>
{% endblock %}

{% block content %}
<!-- Header Actions -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <div style="flex: 1; max-width: 400px;">
        <form method="get" action="/rooms">
            <div class="form-group mb-0">
                <input type="text" name="search" class="form-control" placeholder="Search rooms..." value="{{ search or '' }}">
            </div>
        </form>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <small class="text-muted">SDK Latency: {{ latency_ms }}ms</small>
        <div class="form-check form-switch mb-0 d-flex align-items-center gap-1" title="Auto-refresh every 30s">
            <input class="form-check-input" type="checkbox" role="switch" id="auto-refresh-toggle">
            <label class="form-check-label text-muted" for="auto-refresh-toggle" style="font-size:.85rem;">Auto-refresh</label>
        </div>
        <a href="/rooms/export.csv{% if search %}?search={{ search }}{% endif %}" class="btn btn-secondary btn-sm" title="Export CSV">
            <i class="bi bi-download"></i> Export CSV
        </a>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createRoomModal">
            <i class="bi bi-plus-circle"></i> Create Room
        </button>
    </div>
</div>

<!-- Rooms Table -->
<div class="card" id="rooms-list">
    <div class="card-body">
        {% if rooms %}
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Room Name</th>
                        <th>Participants</th>
                        <th>Max Participants</th>
                        <th>Created</th>
                        <th>Empty Timeout</th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for room in rooms %}
                    <tr>
                        <td>
                            <strong style="color: var(--text-primary);">{{ room.name }}</strong>
                            {% if room.metadata %}
                            <br><small class="text-muted">{{ room.metadata[:50] }}</small>
                            {% endif %}
                        </td>
                        <td>
                            <span class="badge {% if room.num_participants > 0 %}badge-success{% else %}badge-secondary{% endif %}">
                                {{ room.num_participants }}
                            </span>
                        </td>
                        <td>{{ room.max_participants }}</td>
                        <td>{{ room.creation_time }}</td>
                        <td>{{ room.empty_timeout }}s</td>
                        <td style="text-align: right;">
                            <div class="btn-group">
                                <a href="/rooms/{{ room.name }}" class="btn btn-sm btn-secondary" title="View">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-secondary edit-room-btn"
                                    data-room-name="{{ room.name }}"
                                    data-room-metadata="{{ room.metadata or '' }}"
                                    data-bs-toggle="modal" data-bs-target="#editRoomModal"
                                    title="Edit metadata">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button type="button" class="btn btn-sm btn-danger"
                                        hx-post="/rooms/{{ room.name }}/delete"
                                        hx-target="#rooms-list"
                                        hx-swap="outerHTML"
                                        hx-confirm="Are you sure you want to close room '{{ room.name }}'?"
                                        title="Close room">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="bi bi-door-closed"></i>
            </div>
            <div class="empty-state-title">No rooms found</div>
            <div class="empty-state-description">
                {% if search %}
                No rooms matching "{{ search }}"
                {% else %}
                Create your first room to get started
                {% endif %}
            </div>
            {% if not search %}
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createRoomModal">
                <i class="bi bi-plus-circle"></i> Create Room
            </button>
            {% endif %}
        </div>
        {% endif %}
    </div>
</div>

<!-- Auto-refresh polling element (invisible, never swapped) -->
<span id="rooms-auto-poller"></span>

<!-- Edit Room Modal -->
<div class="modal fade" id="editRoomModal" tabindex="-1" aria-labelledby="editRoomModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" id="editRoomForm" action="/rooms/__name__/update">
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                <div class="modal-header">
                    <h5 class="modal-title" id="editRoomModalLabel">Edit Room Metadata</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted" style="font-size:.85rem;">Only metadata can be updated on a live room. Max participants and empty timeout are set at creation time.</p>
                    <div class="form-group mb-0">
                        <label class="form-label">Metadata</label>
                        <textarea class="form-control" name="metadata" id="edit_room_metadata" rows="4" placeholder='{"key":"value"}'></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Create Room Modal -->
<div class="modal fade" id="createRoomModal" tabindex="-1" aria-labelledby="createRoomModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form hx-post="/rooms" 
                  hx-target="#rooms-list" 
                  hx-swap="outerHTML"
                  hx-on::after-request="if(event.detail.successful) { bootstrap.Modal.getInstance(document.getElementById('createRoomModal')).hide(); this.reset(); }">
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                <div class="modal-header">
                    <h5 class="modal-title" id="createRoomModalLabel">Create New Room</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label for="name" class="form-label">Room Name *</label>
                        <input type="text" class="form-control" id="name" name="name" required>
                    </div>
                    <div class="form-group">
                        <label for="max_participants" class="form-label">Max Participants</label>
                        <input type="number" class="form-control" id="max_participants" name="max_participants" value="100">
                    </div>
                    <div class="form-group">
                        <label for="empty_timeout" class="form-label">Empty Timeout (seconds)</label>
                        <input type="number" class="form-control" id="empty_timeout" name="empty_timeout" value="300">
                    </div>
                    <div class="form-group mb-0">
                        <label for="metadata" class="form-label">Metadata (optional)</label>
                        <textarea class="form-control" id="metadata" name="metadata" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <span class="htmx-indicator">Creating...</span>
                        <span class="htmx-content">Create Room</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

{% endblock %}

{% block extra_scripts %}
<script>
document.querySelectorAll('.edit-room-btn').forEach(btn => {
    btn.addEventListener('click', function () {
        const name = this.dataset.roomName;
        document.getElementById('editRoomForm').action = `/rooms/${name}/update`;
        document.getElementById('edit_room_metadata').value = this.dataset.roomMetadata;
        document.getElementById('editRoomModalLabel').textContent = `Edit Room: ${name}`;
    });
});

// Auto-refresh toggle (persisted in localStorage)
(function () {
    const STORAGE_KEY = 'rooms_auto_refresh';
    const INTERVAL = 30;
    const toggle = document.getElementById('auto-refresh-toggle');
    const poller = document.getElementById('rooms-auto-poller');

    function buildPollUrl() {
        const url = new URL(window.location.href);
        url.searchParams.set('partial', '1');
        return url.pathname + url.search;
    }

    function enableAutoRefresh() {
        poller.setAttribute('hx-get', buildPollUrl());
        poller.setAttribute('hx-target', '#rooms-list');
        poller.setAttribute('hx-swap', 'outerHTML');
        poller.setAttribute('hx-trigger', 'every ' + INTERVAL + 's');
        htmx.process(poller);
    }

    function disableAutoRefresh() {
        poller.removeAttribute('hx-trigger');
        htmx.process(poller);
    }

    toggle.addEventListener('change', function () {
        localStorage.setItem(STORAGE_KEY, this.checked ? '1' : '0');
        if (this.checked) {
            enableAutoRefresh();
        } else {
            disableAutoRefresh();
        }
    });

    // Restore persisted preference
    if (localStorage.getItem(STORAGE_KEY) === '1') {
        toggle.checked = true;
        enableAutoRefresh();
    }
}());
</script>
<style>
/* HTMX Loading States */
.htmx-indicator {
    display: none;
}

button.htmx-request .htmx-indicator {
    display: inline;
}

button.htmx-request .htmx-content {
    display: none;
}

.htmx-swapping {
    opacity: 0;
    transition: opacity 0.2s ease-out;
}

.htmx-settling {
    opacity: 1;
    transition: opacity 0.2s ease-in;
}
</style>
{% endblock %}
