{% extends "base.html.j2" %}

{% block title %}Alert Rules — LiveKit Dashboard{% endblock %}
{% block page_title %}Alert Rules{% endblock %}
{% block page_subtitle %}
<p class="text-muted mb-0">Define thresholds that flag unusual conditions in your LiveKit deployment</p>
{% endblock %}

{% block content %}
<div class="container-fluid px-4 py-4">

  {% set triggered_count = evaluated | selectattr(1) | list | length %}
  {% if triggered_count > 0 %}
  <div class="alert alert-warning d-flex align-items-center gap-2 mb-4" role="alert">
    <i class="bi bi-exclamation-triangle-fill"></i>
    <span>{{ triggered_count }} alert{{ 's' if triggered_count != 1 else '' }} currently triggered</span>
  </div>
  {% endif %}

  <!-- Webhook notification config -->
  <div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
      <h6 class="mb-0"><i class="bi bi-send me-2"></i>Webhook notifications</h6>
      {% if notif_config.last_fired %}
      <small class="text-muted">Last fired: {{ notif_config.last_fired }}</small>
      {% endif %}
    </div>
    <div class="card-body">
      <form method="post" action="/alerts/notify/configure" class="row g-2 align-items-end">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        <div class="col-sm-6">
          <label class="form-label small">Webhook URL</label>
          <input type="url" name="webhook_url" class="form-control form-control-sm"
                 placeholder="https://your-endpoint.example.com/hook"
                 value="{{ notif_config.webhook_url }}">
        </div>
        <div class="col-sm-2">
          <label class="form-label small">Cooldown (min)</label>
          <input type="number" name="cooldown_minutes" class="form-control form-control-sm"
                 min="1" max="1440" value="{{ notif_config.cooldown_minutes }}">
        </div>
        <div class="col-sm-2">
          <button type="submit" class="btn btn-primary btn-sm w-100">Save</button>
        </div>
        {% if notif_config.webhook_url %}
        <div class="col-sm-2">
          <form method="post" action="/alerts/notify/send" class="m-0">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
            <button type="submit" class="btn btn-outline-secondary btn-sm w-100"
                    title="Force-fire webhook now, bypassing cooldown">
              <i class="bi bi-send"></i> Notify now
            </button>
          </form>
        </div>
        {% endif %}
      </form>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-header"><h6 class="mb-0">Create alert rule</h6></div>
    <div class="card-body">
      <form method="post" action="/alerts" class="row g-2 align-items-end">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        <div class="col-sm-3">
          <label class="form-label small">Name</label>
          <input type="text" name="name" class="form-control form-control-sm"
                 placeholder="e.g. High API latency" required>
        </div>
        <div class="col-sm-2">
          <label class="form-label small">Metric</label>
          <select name="metric" class="form-select form-select-sm">
            {% for key, label in metrics.items() %}
            <option value="{{ key }}">{{ label }}</option>
            {% endfor %}
          </select>
        </div>
        <div class="col-sm-1">
          <label class="form-label small">Op</label>
          <select name="operator" class="form-select form-select-sm">
            {% for op in operators %}
            <option value="{{ op }}">{{ op }}</option>
            {% endfor %}
          </select>
        </div>
        <div class="col-sm-2">
          <label class="form-label small">Threshold</label>
          <input type="number" name="threshold" step="any" class="form-control form-control-sm"
                 value="10" required>
        </div>
        <div class="col-sm-2">
          <label class="form-label small">Severity</label>
          <select name="severity" class="form-select form-select-sm">
            {% for s in severities %}
            <option value="{{ s }}">{{ s | capitalize }}</option>
            {% endfor %}
          </select>
        </div>
        <div class="col-sm-2">
          <button type="submit" class="btn btn-primary btn-sm w-100">
            <i class="bi bi-plus-circle"></i> Add Rule
          </button>
        </div>
      </form>
    </div>
  </div>

  {% if not evaluated %}
  <div class="card border-0 bg-body-tertiary text-center py-5">
    <div class="card-body">
      <i class="bi bi-bell fs-1 text-muted"></i>
      <p class="mt-3 text-muted">No alert rules yet. Create one above.</p>
    </div>
  </div>
  {% else %}
  <div class="table-responsive">
    <table class="table table-sm align-middle">
      <thead>
        <tr>
          <th>Status</th>
          <th>Name</th>
          <th>Rule</th>
          <th>Severity</th>
          <th>Current value</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {% for rule, is_triggered in evaluated %}
        <tr {% if is_triggered %}class="table-warning"{% endif %}>
          <td>
            {% if not rule.enabled %}
            <span class="badge bg-secondary">Disabled</span>
            {% elif is_triggered %}
            <span class="badge bg-warning text-dark">
              <i class="bi bi-exclamation-triangle"></i> Triggered
            </span>
            {% else %}
            <span class="badge bg-success">
              <i class="bi bi-check-circle"></i> OK
            </span>
            {% endif %}
          </td>
          <td class="fw-semibold">{{ rule.name }}</td>
          <td class="font-monospace small text-muted">
            {{ metrics.get(rule.metric, rule.metric) }} {{ rule.operator }} {{ rule.threshold }}
          </td>
          <td>
            {% if rule.severity == 'critical' %}
            <span class="badge bg-danger">critical</span>
            {% else %}
            <span class="badge bg-warning text-dark">warning</span>
            {% endif %}
          </td>
          <td class="small text-muted">
            {{ stats | attr(rule.metric) if stats else '—' }}
          </td>
          <td class="text-end">
            <form method="post" action="/alerts/{{ rule.id }}/toggle" class="d-inline">
              <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
              <button type="submit" class="btn btn-sm btn-outline-secondary"
                      title="{{ 'Enable' if not rule.enabled else 'Disable' }}">
                <i class="bi bi-{{ 'play' if not rule.enabled else 'pause-circle' }}"></i>
              </button>
            </form>
            <form method="post" action="/alerts/{{ rule.id }}/delete" class="d-inline ms-1">
              <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
              <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete rule"
                      onclick="return confirm('Delete this rule?')">
                <i class="bi bi-trash"></i>
              </button>
            </form>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}

</div>
{% endblock %}
